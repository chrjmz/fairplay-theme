{% liquid
  assign selected_product = section.settings.product
  if selected_product == blank and product != blank
    assign selected_product = product
  endif

  assign default_buy_link = routes.all_products_collection_url
  assign selected_product_handle = selected_product.handle | downcase
  assign selected_product_title = selected_product.title | downcase
  assign product_is_placeholder = false
  if selected_product_handle == 'aaaa' or selected_product_title == 'aaaa'
    assign product_is_placeholder = true
  endif

  if section.settings.buy_link != blank
    assign buy_link = section.settings.buy_link
  elsif selected_product != blank and product_is_placeholder == false
    assign buy_link = selected_product.url
  else
    assign buy_link = default_buy_link
  endif
  assign anchor_id = section.settings.anchor_id | strip
  assign video_embed_url = section.settings.video_embed_url
%}

{{ 'fairplay-home.css' | asset_url | stylesheet_tag }}

<section
  {% if anchor_id != blank %}
    id="{{ anchor_id | escape }}"
  {% endif %}
  class="fairplay-home-section fairplay-home-band section section--full-width color-scheme-1"
  style="--fairplay-padding-top: {{ section.settings.padding_block_start }}px; --fairplay-padding-bottom: {{ section.settings.padding_block_end }}px; --fairplay-video-width: {{ section.settings.video_width_percent | default: 46 }}%; --fairplay-video-offset-y: {{ section.settings.video_offset_y | default: 0 }}px; --fairplay-video-offset-y-mobile: {{ section.settings.video_offset_y_mobile | default: 0 }}px;"
>
  <div class="fairplay-home-section__wrap fairplay-home-band__stack">
    <div class="fairplay-home-band__bar">
      <div class="fairplay-home-band__statement">
        {{ section.settings.statement }}
      </div>
      <a
        href="{{ buy_link }}"
        class="button fairplay-home-button fairplay-home-button--light"
      >
        {{ section.settings.button_label }}
      </a>
    </div>

    {% if video_embed_url != blank %}
      <div class="fairplay-home-band__video">
        <div class="fairplay-home-band__video-card">
          <iframe
            src="{{ video_embed_url }}"
            title="Video Fair Play For Men"
            loading="lazy"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
          ></iframe>
        </div>
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Fair Play Video",
  "tag": "section",
  "class": "section-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "anchor_id",
      "label": "Anchor ID",
      "default": "video"
    },
    {
      "type": "richtext",
      "id": "statement",
      "label": "Statement",
      "default": "<p>Con <strong>Fair Play For Men</strong> estarás preparado para jugar desde el <strong>primer momento</strong></p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Comprar"
    },
    {
      "type": "product",
      "id": "product",
      "label": "Linked product"
    },
    {
      "type": "url",
      "id": "buy_link",
      "label": "Fallback buy link"
    },
    {
      "type": "url",
      "id": "video_embed_url",
      "label": "Video embed URL"
    },
    {
      "type": "range",
      "id": "video_width_percent",
      "label": "Video width",
      "min": 30,
      "max": 100,
      "step": 2,
      "unit": "%",
      "default": 46
    },
    {
      "type": "range",
      "id": "video_offset_y",
      "label": "Video vertical position",
      "min": -200,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "video_offset_y_mobile",
      "label": "Video mobile vertical position",
      "min": -160,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_block_start",
      "label": "Top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_block_end",
      "label": "Bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 32
    }
  ],
  "presets": [
    {
      "name": "Fair Play Video"
    }
  ]
}
{% endschema %}
