{% liquid
  assign default_buy_link = 'https://fairplay4men.com/producto/fair-play-4-men/'
  assign buy_link = section.settings.buy_link | default: default_buy_link
  assign anchor_id = section.settings.anchor_id | strip

  if section.settings.product_image != blank
    assign product_image = section.settings.product_image | image_url: width: 900
  else
    assign product_image = 'https://fairplay4men.com/wp-content/uploads/2023/08/tarro_fairplay-1.png'
  endif

  assign form_id = 'ContactForm-' | append: section.id
%}

<div class="section-background color-scheme-1"></div>
<section
  {% if anchor_id != blank %}
    id="{{ anchor_id | escape }}"
  {% endif %}
  class="fairplay-contact section section--page-width color-scheme-1"
  style="--fairplay-contact-top: {{ section.settings.padding-block-start }}px; --fairplay-contact-bottom: {{ section.settings.padding-block-end }}px; --fairplay-contact-product-width: {{ section.settings.product_image_width | default: 180 }}px; --fairplay-contact-product-width-mobile: {{ section.settings.product_image_width_mobile | default: 148 }}px;"
>
  <div class="fairplay-contact__grid">
    <div class="fairplay-contact__copy">
      <h2>{{ section.settings.title }}</h2>
      {% if section.settings.intro != blank %}
        <p class="fairplay-contact__intro">{{ section.settings.intro }}</p>
      {% endif %}

      {% form 'contact', id: form_id, class: 'fairplay-contact__form' %}
        {% if form.posted_successfully? %}
          <div class="fairplay-contact__message fairplay-contact__message--success">
            Gracias. Recibimos tus datos y te contactaremos pronto.
          </div>
        {% endif %}

        {% if form.errors %}
          <div class="fairplay-contact__message fairplay-contact__message--error">
            {{ form.errors | default_errors }}
          </div>
        {% endif %}

        <input
          type="hidden"
          name="contact[Form]"
          value="Fair Play CTA"
        >

        <textarea
          class="fairplay-contact__hidden"
          name="contact[body]"
        >Quiero recibir mas informacion sobre Fair Play For Men.</textarea>

        <div class="fairplay-contact__fields">
          <input
            type="text"
            name="contact[name]"
            placeholder="* Nombre"
            value="{% if form.name %}{{ form.name }}{% endif %}"
            required
          >

          <input
            type="email"
            name="contact[email]"
            placeholder="* Correo electronico"
            value="{% if form.email %}{{ form.email }}{% endif %}"
            required
          >

          <input
            type="tel"
            name="contact[Telefono]"
            placeholder="Telefono"
            value="{% if form['Telefono'] %}{{ form['Telefono'] }}{% endif %}"
          >

          <select name="contact[Pais]">
            <option value="">Elige el pais</option>
            <option value="Colombia">Colombia</option>
            <option value="Mexico">Mexico</option>
            <option value="Chile">Chile</option>
            <option value="Peru">Peru</option>
            <option value="Otro">Otro</option>
          </select>

          <input
            type="text"
            name="contact[Ciudad]"
            placeholder="Ciudad"
            value="{% if form['Ciudad'] %}{{ form['Ciudad'] }}{% endif %}"
          >
        </div>

        <label class="fairplay-contact__checkbox">
          <input
            type="checkbox"
            name="contact[Autorizo informacion]"
            value="Si"
          >
          <span>Estoy de acuerdo en recibir informacion relacionada con Fair Play.</span>
        </label>

        <label class="fairplay-contact__checkbox">
          <input
            type="checkbox"
            name="contact[Acepta privacidad]"
            value="Si"
            required
          >
          <span>Estoy de acuerdo con el manejo de mis datos y la politica de privacidad.</span>
        </label>

        <button
          type="submit"
          class="button-secondary fairplay-contact__submit"
        >
          Enviar
        </button>
      {% endform %}
    </div>

    <aside class="fairplay-contact__product-card">
      <img
        src="{{ product_image }}"
        alt="Fair Play For Men"
        loading="lazy"
      >
      {% if section.settings.product_title != blank %}
        <h3>{{ section.settings.product_title }}</h3>
      {% endif %}
      {% if section.settings.product_copy != blank %}
        <p>{{ section.settings.product_copy }}</p>
      {% endif %}
      <a
        href="{{ buy_link }}"
        class="button fairplay-contact__buy"
      >
        {{ section.settings.button_label }}
      </a>
    </aside>
  </div>
</section>

{% stylesheet %}
  .fairplay-contact {
    --fairplay-contact-ink: #52545a;
    --fairplay-contact-muted: #7a7b80;
    --fairplay-contact-border: #cecdc9;
    --fairplay-contact-green: #90ab72;
    padding-block: var(--fairplay-contact-top) var(--fairplay-contact-bottom);
    background: #fff;
  }

  .fairplay-contact__grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 210px;
    gap: clamp(2rem, 6vw, 5rem);
    align-items: start;
    max-width: 860px;
    margin-inline: auto;
  }

  .fairplay-contact__copy,
  .fairplay-contact__form {
    display: grid;
    gap: 0.85rem;
  }

  .fairplay-contact__copy h2,
  .fairplay-contact__product-card h3 {
    margin: 0;
    color: var(--fairplay-contact-ink);
    letter-spacing: -0.03em;
  }

  .fairplay-contact__copy h2 {
    font-size: clamp(2rem, 4.2vw, 3rem);
    line-height: 1.08;
    font-weight: 300;
    max-width: 14ch;
  }

  .fairplay-contact__intro {
    margin: 0;
    color: #9a9ba0;
    font-size: 0.72rem;
    line-height: 1.5;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .fairplay-contact__fields {
    display: grid;
    gap: 0.55rem;
  }

  .fairplay-contact__fields input,
  .fairplay-contact__fields select {
    width: 100%;
    min-height: 40px;
    padding: 0.7rem 0.85rem;
    border: 1px solid var(--fairplay-contact-border);
    border-radius: 0;
    background: #fff;
    color: var(--fairplay-contact-ink);
    font: inherit;
    font-size: 0.92rem;
    transition: border-color var(--animation-speed) var(--animation-easing), box-shadow var(--animation-speed) var(--animation-easing);
  }

  .fairplay-contact__fields input:focus,
  .fairplay-contact__fields select:focus {
    outline: none;
    border-color: var(--fairplay-contact-green);
    box-shadow: 0 0 0 4px rgb(144 171 114 / 0.12);
  }

  .fairplay-contact__checkbox {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 0.6rem;
    align-items: start;
    color: var(--fairplay-contact-muted);
    font-size: 0.88rem;
    line-height: 1.45;
  }

  .fairplay-contact__checkbox input {
    margin-top: 0.2rem;
    accent-color: var(--fairplay-contact-green);
  }

  .fairplay-contact__submit {
    justify-self: start;
    min-width: 112px;
    min-height: 36px;
    border-radius: 0;
    color: var(--fairplay-contact-ink);
    border-color: #b7b8bc;
    background: #fff;
  }

  .fairplay-contact__submit:hover {
    background: rgb(82 84 90 / 0.05);
  }

  .fairplay-contact__product-card {
    display: grid;
    justify-items: center;
    gap: 0.85rem;
    padding: 0;
    text-align: center;
  }

  .fairplay-contact__product-card img {
    width: min(100%, var(--fairplay-contact-product-width, 180px));
    object-fit: contain;
  }

  .fairplay-contact__product-card h3 {
    font-size: 1rem;
    font-weight: 500;
  }

  .fairplay-contact__product-card p {
    margin: 0;
    color: var(--fairplay-contact-muted);
    font-size: 0.86rem;
    line-height: 1.55;
  }

  .fairplay-contact__buy {
    width: 100%;
    max-width: 140px;
    min-height: 36px;
    border-radius: 0;
    background: #fff;
    border-color: #b7b8bc;
    color: var(--fairplay-contact-ink);
  }

  .fairplay-contact__buy:hover {
    background: rgb(82 84 90 / 0.05);
    border-color: #a5a6aa;
  }

  .fairplay-contact__message {
    padding: 0.9rem 1rem;
    border-radius: 0;
    font-size: 0.95rem;
  }

  .fairplay-contact__message--success {
    background: rgb(144 171 114 / 0.12);
    color: #496333;
  }

  .fairplay-contact__message--error {
    background: rgb(168 77 77 / 0.1);
    color: #8e4141;
  }

  .fairplay-contact__message :is(ul, li, p) {
    margin: 0;
  }

  .fairplay-contact__hidden {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    opacity: 0;
    pointer-events: none;
  }

  @media screen and (max-width: 989px) {
    .fairplay-contact__grid {
      grid-template-columns: 1fr;
    }

    .fairplay-contact__product-card {
      justify-items: start;
      text-align: left;
    }
  }

  @media screen and (max-width: 749px) {
    .fairplay-contact__copy h2 {
      max-width: none;
    }

    .fairplay-contact__product-card img {
      width: min(100%, var(--fairplay-contact-product-width-mobile, 150px));
    }

    .fairplay-contact__submit,
    .fairplay-contact__buy {
      width: auto;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Fair Play Contact CTA",
  "tag": "section",
  "class": "section-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "anchor_id",
      "label": "Anchor ID",
      "default": "contacto"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Que esperas para unirte al juego?"
    },
    {
      "type": "textarea",
      "id": "intro",
      "label": "Intro",
      "default": "Los campos marcados con * son obligatorios"
    },
    {
      "type": "image_picker",
      "id": "product_image",
      "label": "Product image"
    },
    {
      "type": "header",
      "content": "Product image size"
    },
    {
      "type": "range",
      "id": "product_image_width",
      "label": "Desktop width",
      "min": 100,
      "max": 280,
      "step": 4,
      "unit": "px",
      "default": 180
    },
    {
      "type": "range",
      "id": "product_image_width_mobile",
      "label": "Mobile width",
      "min": 80,
      "max": 220,
      "step": 4,
      "unit": "px",
      "default": 148
    },
    {
      "type": "text",
      "id": "product_title",
      "label": "Product title",
      "default": "Fair Play 4 Men"
    },
    {
      "type": "textarea",
      "id": "product_copy",
      "label": "Product copy",
      "default": "Complemento alimenticio con fibra dietaria para una preparacion mas simple y limpia."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Comprar"
    },
    {
      "type": "url",
      "id": "buy_link",
      "label": "Buy link"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 64
    }
  ],
  "presets": [
    {
      "name": "Fair Play Contact CTA"
    }
  ]
}
{% endschema %}
