{% liquid
  assign default_buy_link = 'https://fairplay4men.com/producto/fair-play-4-men/'
  assign buy_link = section.settings.buy_link | default: default_buy_link
  assign video_embed_url = section.settings.video_embed_url | default: 'https://www.youtube.com/embed/JVkUjvbwGYM'

  if section.settings.hero_background != blank
    assign hero_background = section.settings.hero_background | image_url: width: 1800
  else
    assign hero_background = 'https://fairplay4men.com/wp-content/uploads/2021/04/fair-play-for-men-f2.png'
  endif

  if section.settings.hero_background_mobile != blank
    assign hero_background_mobile = section.settings.hero_background_mobile | image_url: width: 900
  else
    assign hero_background_mobile = 'https://fairplay4men.com/wp-content/uploads/2021/04/foto_pareja.jpg'
  endif

  if section.settings.hero_product != blank
    assign hero_product = section.settings.hero_product | image_url: width: 800
  else
    assign hero_product = 'https://fairplay4men.com/wp-content/uploads/2023/08/tarro_fairplay-1.png'
  endif

  if section.settings.intro_image != blank
    assign intro_image = section.settings.intro_image | image_url: width: 1600
  else
    assign intro_image = 'https://fairplay4men.com/wp-content/uploads/2021/04/fair-play-2.jpg'
  endif

  if section.settings.intro_image_mobile != blank
    assign intro_image_mobile = section.settings.intro_image_mobile | image_url: width: 900
  else
    assign intro_image_mobile = 'https://fairplay4men.com/wp-content/uploads/2021/04/foto_movil_1_1-2.png'
  endif

  if section.settings.dosage_image != blank
    assign dosage_image = section.settings.dosage_image | image_url: width: 1000
  else
    assign dosage_image = 'https://fairplay4men.com/wp-content/uploads/2021/04/fair-play-for-men-digestion.png'
  endif

  if section.settings.detail_image != blank
    assign detail_image = section.settings.detail_image | image_url: width: 900
  else
    assign detail_image = 'https://fairplay4men.com/wp-content/uploads/2023/08/tarro_fairplay-1.png'
  endif

  if section.settings.detail_diagram_image != blank
    assign detail_diagram_image = section.settings.detail_diagram_image | image_url: width: 900
  else
    assign detail_diagram_image = 'https://fairplay4men.com/wp-content/uploads/2021/04/Recurso-8egoshop-2.png'
  endif

  if section.settings.detail_diagram_mobile != blank
    assign detail_diagram_mobile = section.settings.detail_diagram_mobile | image_url: width: 700
  else
    assign detail_diagram_mobile = 'https://fairplay4men.com/wp-content/uploads/2021/04/fairPlay_landing_movilno-hacer-caso-a-fotos-04.png'
  endif

  if section.settings.banner_image != blank
    assign banner_image = section.settings.banner_image | image_url: width: 1800
  else
    assign banner_image = 'https://fairplay4men.com/wp-content/uploads/2021/04/landing_FairPlay_ajustes-01-1.png'
  endif

  if section.settings.banner_image_mobile != blank
    assign banner_image_mobile = section.settings.banner_image_mobile | image_url: width: 900
  else
    assign banner_image_mobile = 'https://fairplay4men.com/wp-content/uploads/2021/04/foto_movil_2_1-3.png'
  endif

  if section.settings.warning_image != blank
    assign warning_image = section.settings.warning_image | image_url: width: 560
  else
    assign warning_image = 'https://fairplay4men.com/wp-content/uploads/2021/04/advertencia.svg'
  endif
%}

<div class="section-background color-scheme-1"></div>
<section
  class="fairplay-landing section section--full-width color-scheme-1"
  style="--fairplay-padding-top: {{ section.settings.padding-block-start }}px; --fairplay-padding-bottom: {{ section.settings.padding-block-end }}px;"
>
  <div class="fairplay-landing__hero">
    <div class="fairplay-landing__hero-copy">
      <p class="fairplay-landing__eyebrow">Play clean, play better</p>
      <h1>Con Fair Play For Men estaras preparado para jugar desde el primer momento</h1>
      <p class="fairplay-landing__lede">
        Un suplemento de fibra dietaria pensado para mejorar el transito intestinal, ayudarte a mantener una mejor
        higiene personal y reducir el tiempo de preparacion antes de tus encuentros.
      </p>
    </div>

    <div class="fairplay-landing__hero-stage">
      <picture>
        <source
          media="(max-width: 749px)"
          srcset="{{ hero_background_mobile }}"
        >
        <img
          class="fairplay-landing__hero-image"
          src="{{ hero_background }}"
          alt="Fair Play For Men"
          loading="lazy"
        >
      </picture>

      <a
        class="fairplay-landing__hero-product"
        href="{{ buy_link }}"
        aria-label="Comprar Fair Play For Men"
      >
        <img
          src="{{ hero_product }}"
          alt="Envase Fair Play For Men"
          loading="lazy"
        >
      </a>
    </div>
  </div>

  <div class="fairplay-landing__statement-band">
    <div class="fairplay-landing__statement-copy">
      <p>
        Con <strong>Fair Play For Men</strong> estaras preparado para jugar desde el <strong>primer momento</strong>.
      </p>
    </div>
    <a
      href="{{ buy_link }}"
      class="button fairplay-landing__button fairplay-landing__button--light"
    >
      Comprar
    </a>
  </div>

  <div class="fairplay-landing__video-shell">
    <div class="fairplay-landing__video-card">
      <iframe
        src="{{ video_embed_url }}"
        title="Video Fair Play For Men"
        loading="lazy"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen
      ></iframe>
    </div>
  </div>

  <div class="fairplay-landing__section fairplay-landing__section--intro">
    <div class="fairplay-landing__section-header">
      <p class="fairplay-landing__eyebrow">Que es Fair Play For Men?</p>
      <h2>Una rutina mas limpia y placentera desde el primer momento</h2>
    </div>

    <div class="fairplay-landing__body-copy fairplay-landing__body-copy--wide">
      <p>
        <strong>Fair Play For Men</strong> es un suplemento de fibra dietaria que ayuda a mantener un adecuado
        transito intestinal y contribuye con la higiene personal. En pocas palabras, es un aliado para experimentar
        encuentros mas limpios y placenteros.
      </p>
      <p>
        Las fibras 100% naturales, debidamente hidratadas con agua, funcionan como un agente de limpieza a medida que
        pasan a traves del sistema digestivo, reduciendo significativamente el uso de enemas y el tiempo que dedicas
        para estar preparado.
      </p>
      <p>
        Adicionalmente, nuestra formula exclusiva incluye <strong>Ganoderma Lucidum</strong> y
        <strong>Colageno Hidrolizado</strong>, ingredientes que fortalecen el sistema inmunologico y nutren el
        cabello, la piel, los huesos y las unas.
      </p>
    </div>
  </div>

  <div class="fairplay-landing__feature-media">
    <picture>
      <source
        media="(max-width: 749px)"
        srcset="{{ intro_image_mobile }}"
      >
      <img
        src="{{ intro_image }}"
        alt="Que es Fair Play For Men"
        loading="lazy"
      >
    </picture>
  </div>

  <div class="fairplay-landing__section fairplay-landing__section--benefits">
    <div class="fairplay-landing__benefits-copy">
      <p class="fairplay-landing__eyebrow">Y tu... Como juegas?</p>
      <h2>Mas bienestar para tu cuerpo, menos pasos antes de disfrutar</h2>
      <p>
        <strong>Fair Play For Men</strong> reune la mejor seleccion de ingredientes que le aportan a tu organismo la
        cantidad de fibra necesaria para garantizar un adecuado transito intestinal que, junto a una sensacion de
        bienestar, reducira significativamente el uso de enemas y el tiempo que dedicas para disfrutar de un
        encuentro sexual mas limpio y placentero.
      </p>
      <p>
        De otro lado, nuestra formula exclusiva con <strong>Ganoderma Lucidum</strong> y
        <strong>Colageno Hidrolizado</strong>, potencia la capacidad de defensa del organismo, funciona como
        antioxidante y contribuye al fortalecimiento de la piel, las unas, el cabello y las articulaciones.
      </p>
      <p class="fairplay-landing__benefits-highlight">
        Ya lo sabes, con Fair Play For Men, estaras preparado para jugar desde el primer momento.
      </p>
    </div>

    <div class="fairplay-landing__digest-card">
      <img
        src="{{ dosage_image }}"
        alt="Beneficios digestivos de Fair Play"
        loading="lazy"
      >
      <div class="fairplay-landing__digest-copy">
        <span class="fairplay-landing__digest-label">Fair Play For Men</span>
        <strong>Evacua totalmente tu sistema intestinal, sin dejar residuos que incomodan.</strong>
      </div>
    </div>
  </div>

  <div
    id="fairplay-composition-{{ section.id }}"
    class="fairplay-landing__section fairplay-landing__section--composition"
  >
    <div class="fairplay-landing__section-header fairplay-landing__section-header--center">
      <p class="fairplay-landing__eyebrow">Composicion</p>
      <h2>Ingredientes que juegan a tu favor</h2>
    </div>

    <div class="fairplay-landing__composition-grid">
      <article class="fairplay-landing__composition-card">
        <img
          src="https://fairplay4men.com/wp-content/uploads/2021/04/Recurso-5egoshop.png"
          alt="Chia, linaza y psyllium"
          loading="lazy"
        >
        <h3>Chia, linaza y psyllium</h3>
        <p class="fairplay-landing__composition-meta">Fibra</p>
        <p>
          Debidamente hidratados con agua, estos ingredientes facilitan el transito intestinal y aportan proteinas,
          antioxidantes, acidos grasos y omega-3.
        </p>
      </article>

      <article class="fairplay-landing__composition-card">
        <img
          src="https://fairplay4men.com/wp-content/uploads/2021/04/Recurso-6egoshop.png"
          alt="Ganoderma Lucidum"
          loading="lazy"
        >
        <h3>Ganoderma Lucidum</h3>
        <p>
          Hongo milenario al que se le reconocen efectos potencialmente terapeuticos como inmunoreguladores,
          antioxidantes y de bienestar general.
        </p>
      </article>

      <article class="fairplay-landing__composition-card">
        <img
          src="https://fairplay4men.com/wp-content/uploads/2021/04/Recurso-7egoshop.png"
          alt="Colageno Hidrolizado"
          loading="lazy"
        >
        <h3>Colageno Hidrolizado</h3>
        <p>
          Ayuda a estimular la produccion de colageno en el organismo, mejorando la piel y fortaleciendo
          articulaciones, unas, huesos y cabello.
        </p>
      </article>

      <article class="fairplay-landing__composition-card">
        <img
          src="https://fairplay4men.com/wp-content/uploads/2022/07/1vivimania.png"
          alt="Vitamina C"
          loading="lazy"
        >
        <h3>Vitamina C</h3>
        <p>
          Antioxidante que protege las celulas y participa en la formacion de vasos sanguineos, musculos, cartilagos
          y colageno.
        </p>
      </article>

      <article class="fairplay-landing__composition-card">
        <img
          src="https://fairplay4men.com/wp-content/uploads/2022/07/1aloloe.png"
          alt="Aloe Vera"
          loading="lazy"
        >
        <h3>Aloe Vera</h3>
        <p>
          Regula el pH del aparato digestivo y ayuda a evitar afecciones como ulceras, digestiones lentas o pesadez
          estomacal.
        </p>
      </article>
    </div>
  </div>

  <div class="fairplay-landing__notice">
    <img
      class="fairplay-landing__notice-image"
      src="{{ warning_image }}"
      alt="Advertencia Fair Play"
      loading="lazy"
    >
    <p>
      Mantengase fuera del alcance de los ninos. Bajo condiciones de buen uso y almacenamiento, este producto tiene
      una vida util de 24 meses. Evite consumir el producto si el sello de la tapa esta roto o deteriorado. Verifique
      su fecha de vencimiento antes de consumir. <strong>Este producto es un suplemento dietario. No es un
      medicamento y no suple una alimentacion equilibrada.</strong>
    </p>
  </div>

  <div class="fairplay-landing__section fairplay-landing__section--recommendations">
    <div class="fairplay-landing__recommendations-copy">
      <p class="fairplay-landing__eyebrow">Recomendaciones</p>
      <h2>Juega a tu ritmo, <strong>juega limpio</strong></h2>

      <div class="fairplay-landing__body-copy">
        <p>
          <strong>Precauciones:</strong> No exceda la dosis diaria recomendada. Este producto debe ser consumido luego
          de ser diluido en agua; consumirlo en polvo podria causar asfixia. Si al consumir el producto surgen
          sintomas como dolor en el pecho, vomito, dificultad para respirar o tragar, o alguna otra reaccion
          alergica, busque inmediatamente atencion medica.
        </p>
        <p>
          Evite su uso en mujeres en embarazo o en periodo de lactancia, asi como en personas con dolor abdominal o
          sintomas de diarrea. En caso de estar consumiendo algun medicamento o en medio de un tratamiento medico,
          consulte con su medico antes de hacer uso de este producto. <strong>Producto sugerido para personas mayores
          de 18 anos.</strong>
        </p>
        <p>
          <strong>Conservacion:</strong> Conservese en su envase original, a temperatura ambiente y en un lugar
          fresco, ventilado y seco. Cerciorese de cerrarlo hermeticamente despues de cada uso para evitar su
          contaminacion y humedad.
        </p>
      </div>
    </div>

    <div class="fairplay-landing__recommendations-detail">
      <div class="fairplay-landing__detail-panel fairplay-landing__detail-panel--product">
        <img
          src="{{ detail_image }}"
          alt="Presentacion Fair Play For Men"
          loading="lazy"
        >
        <div>
          <h3>Presentacion</h3>
          <p>
            Fair Play For Men viene en polvo porque al mezclarse con agua hidrata mejor la linaza, la chia y las
            cascaras de psyllium. De esa hidratacion depende la consistencia necesaria para arrastrar los residuos del
            tracto intestinal.
          </p>
        </div>
      </div>

      <div class="fairplay-landing__detail-panel fairplay-landing__detail-panel--diagram">
        <picture>
          <source
            media="(max-width: 749px)"
            srcset="{{ detail_diagram_mobile }}"
          >
          <img
            src="{{ detail_diagram_image }}"
            alt="Modo de uso Fair Play For Men"
            loading="lazy"
          >
        </picture>
        <div>
          <h3>Dosis</h3>
          <p>
            Consumir 6 gramos, equivalentes a 2 porciones del dosificador incluido en el producto, maximo dos veces al
            dia, disueltas en 240 ml de agua.
          </p>
        </div>
      </div>
    </div>
  </div>

  <div class="fairplay-landing__community-banner">
    <picture>
      <source
        media="(max-width: 749px)"
        srcset="{{ banner_image_mobile }}"
      >
      <img
        src="{{ banner_image }}"
        alt="Comunidad Fair Play"
        loading="lazy"
      >
    </picture>
    <span class="fairplay-landing__community-badge">Play</span>
  </div>
</section>

{% stylesheet %}
  .fairplay-landing {
    --fairplay-ink: #505258;
    --fairplay-ink-soft: #6f7177;
    --fairplay-smoke: #f8f7f4;
    --fairplay-paper: #fffdf9;
    --fairplay-border: #ddd7cf;
    --fairplay-green: #90ab72;
    --fairplay-dark: #525357;
    padding-block: var(--fairplay-padding-top) var(--fairplay-padding-bottom);
    color: var(--fairplay-ink);
    background:
      radial-gradient(circle at top right, rgb(144 171 114 / 0.08), transparent 28%),
      linear-gradient(180deg, #fff 0%, #fcfaf7 100%);
  }

  .fairplay-landing h1,
  .fairplay-landing h2,
  .fairplay-landing h3 {
    margin: 0;
    color: var(--fairplay-ink);
    line-height: 1.05;
    letter-spacing: -0.03em;
  }

  .fairplay-landing p {
    margin: 0;
    color: var(--fairplay-ink-soft);
    line-height: 1.75;
  }

  .fairplay-landing strong {
    color: var(--fairplay-ink);
  }

  .fairplay-landing__hero,
  .fairplay-landing__statement-band,
  .fairplay-landing__video-shell,
  .fairplay-landing__section,
  .fairplay-landing__feature-media,
  .fairplay-landing__notice,
  .fairplay-landing__community-banner {
    width: min(1120px, calc(100% - 2rem));
    margin-inline: auto;
  }

  .fairplay-landing__hero {
    display: grid;
    gap: clamp(1rem, 3vw, 2rem);
    padding-top: clamp(0.75rem, 2vw, 1.5rem);
    text-align: center;
  }

  .fairplay-landing__hero-copy {
    display: grid;
    gap: 1rem;
    justify-items: center;
  }

  .fairplay-landing__eyebrow {
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--fairplay-ink-soft);
  }

  .fairplay-landing__hero h1 {
    max-width: 14ch;
    font-size: clamp(2.4rem, 6vw, 4.8rem);
    font-weight: 300;
  }

  .fairplay-landing__lede {
    max-width: 60ch;
    font-size: 1.05rem;
  }

  .fairplay-landing__hero-stage {
    position: relative;
    min-height: clamp(300px, 44vw, 560px);
  }

  .fairplay-landing__hero-stage picture,
  .fairplay-landing__hero-stage img {
    display: block;
    width: 100%;
  }

  .fairplay-landing__hero-image {
    object-fit: contain;
    filter: drop-shadow(0 22px 50px rgb(31 33 39 / 0.14));
  }

  .fairplay-landing__hero-product {
    position: absolute;
    right: clamp(0.75rem, 7vw, 7rem);
    bottom: clamp(-1rem, -1.5vw, -0.25rem);
    width: clamp(118px, 16vw, 188px);
    padding: 0.85rem;
    border-radius: 28px;
    background: rgb(255 255 255 / 0.94);
    box-shadow: 0 18px 44px rgb(44 46 53 / 0.18);
  }

  .fairplay-landing__hero-product img {
    object-fit: contain;
  }

  .fairplay-landing__statement-band {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 1.5rem;
    margin-top: clamp(-2.25rem, -3vw, -1.25rem);
    padding: clamp(1.3rem, 3vw, 1.8rem) clamp(1rem, 4vw, 2.5rem);
    border-radius: 0;
    background: var(--fairplay-dark);
    text-align: center;
  }

  .fairplay-landing__statement-copy {
    max-width: 32rem;
  }

  .fairplay-landing__statement-copy p,
  .fairplay-landing__statement-copy strong {
    color: #fff;
    font-size: clamp(1.05rem, 2vw, 1.5rem);
    line-height: 1.2;
  }

  .fairplay-landing__button {
    min-width: 168px;
    border-radius: 999px;
    padding-inline: 1.8rem;
    background: var(--fairplay-green);
    border-color: var(--fairplay-green);
    color: #fff;
  }

  .fairplay-landing__button:hover {
    background: #7f9b62;
    border-color: #7f9b62;
  }

  .fairplay-landing__button--light {
    background: #fff;
    border-color: #fff;
    color: var(--fairplay-dark);
  }

  .fairplay-landing__button--light:hover {
    background: rgb(255 255 255 / 0.9);
    border-color: rgb(255 255 255 / 0.9);
  }

  .fairplay-landing__video-shell {
    margin-top: clamp(-1.25rem, -2vw, -0.75rem);
  }

  .fairplay-landing__video-card {
    overflow: hidden;
    width: min(700px, calc(100% - 1rem));
    margin-inline: auto;
    border-radius: 28px;
    background: #fff;
    box-shadow: 0 20px 44px rgb(44 46 53 / 0.14);
  }

  .fairplay-landing__video-card iframe {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
    border: 0;
  }

  .fairplay-landing__section {
    padding-top: clamp(4rem, 8vw, 6rem);
  }

  .fairplay-landing__section-header {
    display: grid;
    gap: 0.75rem;
    margin-bottom: clamp(1.5rem, 3vw, 2.5rem);
    justify-items: center;
    text-align: center;
  }

  .fairplay-landing__section-header h2 {
    max-width: 16ch;
    font-size: clamp(2rem, 4vw, 3.2rem);
    font-weight: 300;
  }

  .fairplay-landing__body-copy {
    display: grid;
    gap: 1rem;
  }

  .fairplay-landing__body-copy--wide {
    width: min(760px, 100%);
    margin-inline: auto;
  }

  .fairplay-landing__feature-media {
    overflow: hidden;
    margin-top: clamp(2rem, 4vw, 3rem);
    border-radius: 36px;
    background: var(--fairplay-smoke);
  }

  .fairplay-landing__feature-media img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .fairplay-landing__section--benefits {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(250px, 0.85fr);
    gap: clamp(1.5rem, 4vw, 4rem);
    align-items: start;
  }

  .fairplay-landing__benefits-copy {
    display: grid;
    gap: 1rem;
  }

  .fairplay-landing__benefits-copy h2,
  .fairplay-landing__recommendations-copy h2 {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 300;
  }

  .fairplay-landing__benefits-highlight {
    font-weight: 600;
    color: var(--fairplay-ink);
  }

  .fairplay-landing__digest-card {
    display: grid;
    gap: 1rem;
    justify-items: center;
    padding: 1.6rem;
    border: 1px solid var(--fairplay-border);
    border-radius: 30px;
    background: var(--fairplay-paper);
    text-align: center;
    box-shadow: 0 18px 36px rgb(42 44 50 / 0.06);
  }

  .fairplay-landing__digest-card img {
    width: min(100%, 260px);
    object-fit: contain;
  }

  .fairplay-landing__digest-label {
    display: inline-block;
    margin-bottom: 0.55rem;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--fairplay-green);
  }

  .fairplay-landing__digest-copy strong {
    display: block;
    color: var(--fairplay-ink);
    font-size: 1.02rem;
    line-height: 1.45;
  }

  .fairplay-landing__section--composition {
    padding-top: clamp(4.5rem, 8vw, 6.5rem);
  }

  .fairplay-landing__composition-grid {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 1rem;
  }

  .fairplay-landing__composition-card {
    display: grid;
    align-content: start;
    gap: 0.9rem;
    padding: 1.5rem 1rem;
    border-radius: 28px;
    background: #fff;
    text-align: center;
    box-shadow: 0 16px 38px rgb(37 39 45 / 0.05);
  }

  .fairplay-landing__composition-card img {
    width: min(100%, 88px);
    margin-inline: auto;
    object-fit: contain;
  }

  .fairplay-landing__composition-card h3 {
    font-size: 1.05rem;
    font-weight: 600;
  }

  .fairplay-landing__composition-card p {
    font-size: 0.94rem;
  }

  .fairplay-landing__composition-meta {
    margin-top: -0.35rem;
    font-size: 0.86rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--fairplay-green);
  }

  .fairplay-landing__notice {
    display: grid;
    gap: 1.25rem;
    justify-items: center;
    margin-top: clamp(3rem, 6vw, 5rem);
    padding: clamp(1.5rem, 3vw, 2rem);
    background: var(--fairplay-dark);
    text-align: center;
  }

  .fairplay-landing__notice-image {
    width: min(100%, 280px);
  }

  .fairplay-landing__notice p,
  .fairplay-landing__notice strong {
    color: rgb(255 255 255 / 0.84);
  }

  .fairplay-landing__section--recommendations {
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
    gap: clamp(1.5rem, 4vw, 4rem);
    align-items: start;
  }

  .fairplay-landing__recommendations-copy,
  .fairplay-landing__recommendations-detail {
    display: grid;
    gap: 1.25rem;
  }

  .fairplay-landing__recommendations-copy h2 strong {
    font-weight: 700;
  }

  .fairplay-landing__recommendations-detail {
    gap: 1rem;
  }

  .fairplay-landing__detail-panel {
    display: grid;
    grid-template-columns: minmax(150px, 0.72fr) minmax(0, 1fr);
    gap: 1rem;
    align-items: center;
    padding: 1.3rem;
    border: 1px solid var(--fairplay-border);
    border-radius: 30px;
    background: #fff;
    box-shadow: 0 18px 40px rgb(44 46 53 / 0.06);
  }

  .fairplay-landing__detail-panel img {
    display: block;
    width: 100%;
    object-fit: contain;
  }

  .fairplay-landing__detail-panel h3 {
    margin-bottom: 0.5rem;
    font-size: 1.2rem;
    font-weight: 600;
  }

  .fairplay-landing__community-banner {
    position: relative;
    overflow: hidden;
    margin-top: clamp(4rem, 8vw, 6rem);
    border-radius: 0;
    background: var(--fairplay-dark);
  }

  .fairplay-landing__community-banner img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .fairplay-landing__community-badge {
    position: absolute;
    right: clamp(1rem, 4vw, 2.5rem);
    top: clamp(1rem, 4vw, 2.5rem);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 86px;
    min-height: 86px;
    border-radius: 50%;
    background: rgb(82 83 87 / 0.82);
    color: #fff;
    font-size: 1.25rem;
    font-weight: 600;
    letter-spacing: -0.03em;
  }

  @media screen and (max-width: 1199px) {
    .fairplay-landing__composition-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media screen and (max-width: 989px) {
    .fairplay-landing__statement-band,
    .fairplay-landing__section--benefits,
    .fairplay-landing__section--recommendations,
    .fairplay-landing__detail-panel {
      grid-template-columns: 1fr;
    }

    .fairplay-landing__statement-band {
      display: grid;
      justify-items: center;
    }

    .fairplay-landing__hero-product {
      right: 1rem;
      bottom: -0.5rem;
    }

    .fairplay-landing__composition-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media screen and (max-width: 749px) {
    .fairplay-landing {
      padding-block: max(1rem, var(--fairplay-padding-top)) max(3rem, var(--fairplay-padding-bottom));
    }

    .fairplay-landing__hero,
    .fairplay-landing__statement-band,
    .fairplay-landing__video-shell,
    .fairplay-landing__section,
    .fairplay-landing__feature-media,
    .fairplay-landing__notice,
    .fairplay-landing__community-banner {
      width: min(100%, calc(100% - 1rem));
    }

    .fairplay-landing__hero {
      gap: 0.75rem;
    }

    .fairplay-landing__hero h1 {
      font-size: clamp(2rem, 11vw, 3rem);
    }

    .fairplay-landing__hero-stage {
      min-height: 240px;
    }

    .fairplay-landing__hero-product {
      width: 118px;
      padding: 0.65rem;
    }

    .fairplay-landing__statement-band {
      margin-top: 0;
      padding-inline: 1rem;
    }

    .fairplay-landing__video-shell {
      margin-top: -0.5rem;
    }

    .fairplay-landing__section-header h2,
    .fairplay-landing__benefits-copy h2,
    .fairplay-landing__recommendations-copy h2 {
      max-width: none;
      font-size: clamp(1.85rem, 8vw, 2.4rem);
    }

    .fairplay-landing__composition-grid {
      grid-template-columns: 1fr;
    }

    .fairplay-landing__detail-panel {
      padding: 1rem;
    }

    .fairplay-landing__community-badge {
      min-width: 68px;
      min-height: 68px;
      font-size: 1rem;
    }
  }
{% endstylesheet %}

