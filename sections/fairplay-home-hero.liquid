{% liquid
  assign selected_product = section.settings.product
  if selected_product == blank and product != blank
    assign selected_product = product
  endif

  assign default_buy_link = routes.all_products_collection_url
  assign selected_product_handle = selected_product.handle | downcase
  assign selected_product_title = selected_product.title | downcase
  assign product_is_placeholder = false
  if selected_product_handle == 'aaaa' or selected_product_title == 'aaaa'
    assign product_is_placeholder = true
  endif

  if section.settings.buy_link != blank
    assign buy_link = section.settings.buy_link
  elsif selected_product != blank and product_is_placeholder == false
    assign buy_link = selected_product.url
  else
    assign buy_link = default_buy_link
  endif
  assign anchor_id = section.settings.anchor_id | strip

  if section.settings.hero_background != blank
    assign hero_background = section.settings.hero_background | image_url: width: 1800
  else
    assign hero_background = 'https://fairplay4men.com/wp-content/uploads/2021/04/fair-play-for-men-f2.png'
  endif

  if section.settings.hero_background_mobile != blank
    assign hero_background_mobile = section.settings.hero_background_mobile | image_url: width: 900
  else
    assign hero_background_mobile = 'https://fairplay4men.com/wp-content/uploads/2021/04/foto_pareja.jpg'
  endif

  if section.settings.hero_product != blank
    assign hero_product = section.settings.hero_product | image_url: width: 800
  elsif selected_product != blank and selected_product.featured_image != blank
    assign hero_product = selected_product.featured_image | image_url: width: 800
  else
    assign hero_product = 'https://fairplay4men.com/wp-content/uploads/2023/08/tarro_fairplay-1.png'
  endif

  case section.settings.text_alignment
    when 'left'
      assign justify_items = 'start'
    when 'right'
      assign justify_items = 'end'
    else
      assign justify_items = 'center'
  endcase
%}

{{ 'fairplay-home.css' | asset_url | stylesheet_tag }}

<section
  {% if anchor_id != blank %}
    id="{{ anchor_id | escape }}"
  {% endif %}
  class="fairplay-home-section fairplay-home-hero section section--full-width color-scheme-1"
  style="--fairplay-padding-top: {{ section.settings.padding_block_start }}px; --fairplay-padding-bottom: {{ section.settings.padding_block_end }}px; --fairplay-section-width: {{ section.settings.section_width | default: 1280 }}px; --fairplay-hero-copy-width: {{ section.settings.text_width | default: 1120 }}px; --fairplay-hero-product-width: {{ section.settings.product_image_width | default: 140 }}px; --fairplay-hero-product-width-mobile: {{ section.settings.product_image_width_mobile | default: 96 }}px; --fairplay-hero-product-offset-y: {{ section.settings.product_image_offset_y | default: 0 }}px; --fairplay-hero-product-offset-y-mobile: {{ section.settings.product_image_offset_y_mobile | default: 0 }}px; --fairplay-text-align: {{ section.settings.text_alignment | default: 'center' }}; --fairplay-justify-items: {{ justify_items | default: 'center' }}; --fairplay-title-size: {{ section.settings.title_size | default: 48 }}px; --fairplay-title-size-mobile: {{ section.settings.title_size_mobile | default: 36 }}px;"
>
  <div class="fairplay-home-section__wrap fairplay-home-hero__wrap">
    <div class="fairplay-home-hero__copy">
      {% if section.settings.eyebrow != blank %}
        <p class="fairplay-home-eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}
      {% if section.settings.title != blank %}
        <h1 class="fairplay-home-hero__title">{{ section.settings.title }}</h1>
      {% endif %}
      {% if section.settings.lede != blank %}
        <p class="fairplay-home-hero__lede">{{ section.settings.lede }}</p>
      {% endif %}
    </div>

    <div class="fairplay-home-hero__stage">
      <picture>
        <source
          media="(max-width: 749px)"
          srcset="{{ hero_background_mobile }}"
        >
        <img
          class="fairplay-home-hero__image"
          src="{{ hero_background }}"
          alt="{{ section.settings.image_alt | escape | default: 'Fair Play For Men' }}"
          width="{{ section.settings.hero_background.width | default: 1500 }}"
          height="{{ section.settings.hero_background.height | default: 1001 }}"
          loading="lazy"
        >
      </picture>

      {% if section.settings.button_label != blank %}
        <a
          href="{{ buy_link }}"
          class="button-secondary fairplay-home-hero__button"
        >
          {{ section.settings.button_label }}
        </a>
      {% endif %}

      <a
        class="fairplay-home-hero__product"
        href="{{ buy_link }}"
        aria-label="Comprar {% if selected_product != blank %}{{ selected_product.title | escape }}{% else %}Fair Play For Men{% endif %}"
      >
        <img
          src="{{ hero_product }}"
          alt="{% if selected_product != blank %}{{ selected_product.title | escape }}{% else %}Envase Fair Play For Men{% endif %}"
          width="{{ section.settings.hero_product.width | default: selected_product.featured_image.width | default: 426 }}"
          height="{{ section.settings.hero_product.height | default: selected_product.featured_image.height | default: 641 }}"
          loading="lazy"
        >
      </a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Fair Play Hero",
  "tag": "section",
  "class": "section-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "anchor_id",
      "label": "Anchor ID",
      "default": "fairplay"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Play clean, play better"
    },
    {
      "type": "textarea",
      "id": "title",
      "label": "Title",
      "default": "Play clean, play better"
    },
    {
      "type": "textarea",
      "id": "lede",
      "label": "Intro text",
      "default": ""
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Comprar"
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Hero image alt",
      "default": "Fair Play For Men"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "section_width",
      "label": "Ancho de la seccion",
      "min": 320,
      "max": 1280,
      "step": 20,
      "unit": "px",
      "default": 1280
    },
    {
      "type": "range",
      "id": "text_width",
      "label": "Ancho del texto",
      "min": 280,
      "max": 1280,
      "step": 20,
      "unit": "px",
      "default": 1120
    },
    {
      "type": "image_picker",
      "id": "hero_background",
      "label": "Hero background"
    },
    {
      "type": "image_picker",
      "id": "hero_background_mobile",
      "label": "Hero background mobile"
    },
    {
      "type": "image_picker",
      "id": "hero_product",
      "label": "Hero product image"
    },
    {
      "type": "header",
      "content": "Product image size"
    },
    {
      "type": "range",
      "id": "product_image_width",
      "label": "Desktop width",
      "min": 80,
      "max": 260,
      "step": 4,
      "unit": "px",
      "default": 140
    },
    {
      "type": "range",
      "id": "product_image_width_mobile",
      "label": "Mobile width",
      "min": 60,
      "max": 180,
      "step": 4,
      "unit": "px",
      "default": 96
    },
    {
      "type": "range",
      "id": "product_image_offset_y",
      "label": "Desktop vertical position",
      "min": -200,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "product_image_offset_y_mobile",
      "label": "Mobile vertical position",
      "min": -160,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "product",
      "id": "product",
      "label": "Linked product"
    },
    {
      "type": "url",
      "id": "buy_link",
      "label": "Fallback buy link"
    },
    {
      "type": "header",
      "content": "Texto"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Alineación",
      "options": [
        { "value": "left", "label": "Izquierda" },
        { "value": "center", "label": "Centro" },
        { "value": "right", "label": "Derecha" }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Tamaño título desktop",
      "min": 20,
      "max": 72,
      "step": 2,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "title_size_mobile",
      "label": "Tamaño título mobile",
      "min": 14,
      "max": 52,
      "step": 2,
      "unit": "px",
      "default": 36
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_block_start",
      "label": "Top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_block_end",
      "label": "Bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 8
    }
  ],
  "presets": [
    {
      "name": "Fair Play Hero"
    }
  ]
}
{% endschema %}
