{% liquid
  assign anchor_id = section.settings.anchor_id | strip

  if section.settings.image != blank
    assign feature_image = section.settings.image | image_url: width: 1800
  else
    assign feature_image = 'https://fairplay4men.com/wp-content/uploads/2021/04/fair-play-2.jpg'
  endif

  if section.settings.image_mobile != blank
    assign feature_image_mobile = section.settings.image_mobile | image_url: width: 900
  else
    assign feature_image_mobile = 'https://fairplay4men.com/wp-content/uploads/2021/04/foto_movil_1_1-2.png'
  endif
%}

{{ 'fairplay-home.css' | asset_url | stylesheet_tag }}

<section
  {% if anchor_id != blank %}
    id="{{ anchor_id | escape }}"
  {% endif %}
  class="fairplay-home-section fairplay-home-media section section--full-width color-scheme-1"
  style="--fairplay-padding-top: {{ section.settings.padding_block_start }}px; --fairplay-padding-bottom: {{ section.settings.padding_block_end }}px; --fairplay-section-width: {{ section.settings.section_width | default: 1280 }}px; --fairplay-feature-image-width: {{ section.settings.image_width_percent | default: 100 }}%; --fairplay-media-side-padding: {{ section.settings.padding_inline | default: 0 }}px; --fairplay-media-side-padding-mobile: {{ section.settings.padding_inline_mobile | default: 0 }}px;"
>
  <div class="fairplay-home-section__wrap">
    <div class="fairplay-home-media__card">
      <picture>
        <source
          media="(max-width: 749px)"
          {% if section.settings.image_mobile != blank %}
            srcset="{{ section.settings.image_mobile | image_url: width: 375 }} 375w, {{ section.settings.image_mobile | image_url: width: 750 }} 750w, {{ section.settings.image_mobile | image_url: width: 900 }} 900w"
            sizes="100vw"
          {% else %}
            srcset="{{ feature_image_mobile }}"
          {% endif %}
        >
        <img
          src="{{ feature_image }}"
          {% if section.settings.image != blank %}
            srcset="{{ section.settings.image | image_url: width: 750 }} 750w, {{ section.settings.image | image_url: width: 1100 }} 1100w, {{ section.settings.image | image_url: width: 1500 }} 1500w, {{ section.settings.image | image_url: width: 1800 }} 1800w"
            sizes="(min-width: {{ section.settings.section_width | default: 1280 }}px) {{ section.settings.section_width | default: 1280 }}px, 100vw"
          {% endif %}
          alt="{{ section.settings.image_alt | escape | default: 'Imagen destacada Fair Play' }}"
          width="{{ section.settings.image.width | default: 1500 }}"
          height="{{ section.settings.image.height | default: 770 }}"
          loading="lazy"
        >
      </picture>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Fair Play Feature Image",
  "tag": "section",
  "class": "section-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "anchor_id",
      "label": "Anchor ID",
      "default": "feature-media"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Desktop image"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Mobile image"
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Image alt",
      "default": "Imagen destacada Fair Play"
    },
    {
      "type": "range",
      "id": "image_width_percent",
      "label": "Image width",
      "min": 40,
      "max": 100,
      "step": 2,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "section_width",
      "label": "Section content width",
      "min": 320,
      "max": 1280,
      "step": 20,
      "unit": "px",
      "default": 1280
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_block_start",
      "label": "Top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding_block_end",
      "label": "Bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding_inline",
      "label": "Izquierda y derecha",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_inline_mobile",
      "label": "Izquierda y derecha mobile",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Fair Play Feature Image"
    }
  ]
}
{% endschema %}
