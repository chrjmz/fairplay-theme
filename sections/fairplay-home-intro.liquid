{% liquid
  assign anchor_id = section.settings.anchor_id | strip
  case section.settings.text_alignment
    when 'left'
      assign justify_items = 'start'
    when 'right'
      assign justify_items = 'end'
    else
      assign justify_items = 'center'
  endcase

  case section.settings.text_alignment_mobile
    when 'left'
      assign justify_items_mobile = 'start'
    when 'center'
      assign justify_items_mobile = 'center'
    when 'right'
      assign justify_items_mobile = 'end'
    else
      assign justify_items_mobile = justify_items
  endcase
%}

{{ 'fairplay-home.css' | asset_url | stylesheet_tag }}

<section
  {% if anchor_id != blank %}
    id="{{ anchor_id | escape }}"
  {% endif %}
  class="fairplay-home-section fairplay-home-intro section section--full-width color-scheme-1"
  style="--fairplay-padding-top: {{ section.settings.padding_block_start }}px; --fairplay-padding-bottom: {{ section.settings.padding_block_end }}px; --fairplay-section-width: {{ section.settings.section_width | default: 900 }}px; --fairplay-intro-text-width: {{ section.settings.text_width | default: 560 }}px; --fairplay-text-align: {{ section.settings.text_alignment | default: 'center' }}; --fairplay-body-align: {{ section.settings.text_alignment | default: 'left' }}; --fairplay-justify-items: {{ justify_items | default: 'center' }}; --fairplay-text-align-mobile: {{ section.settings.text_alignment_mobile | default: section.settings.text_alignment | default: 'center' }}; --fairplay-justify-items-mobile: {{ justify_items_mobile | default: justify_items | default: 'center' }}; --fairplay-title-size: {{ section.settings.title_size | default: 48 }}px; --fairplay-title-size-mobile: {{ section.settings.title_size_mobile | default: 36 }}px;"
>
  <div class="fairplay-home-section__wrap fairplay-home-intro__wrap">
    <div class="fairplay-home-intro__header">
      {% if section.settings.eyebrow != blank %}
        <p class="fairplay-home-eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}
      {% if section.settings.title != blank %}
        <h2 class="fairplay-home-title">{{ section.settings.title }}</h2>
      {% endif %}
    </div>

    <div class="fairplay-home-body-copy fairplay-home-intro__body">
      {{ section.settings.body_1 }}
      {{ section.settings.body_2 }}
      {{ section.settings.body_3 }}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Fair Play Intro",
  "tag": "section",
  "class": "section-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "anchor_id",
      "label": "Anchor ID",
      "default": "que-es-fairplay"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Que es Fair Play For Men?"
    },
    {
      "type": "textarea",
      "id": "title",
      "label": "Title",
      "default": "Una rutina mas limpia y placentera desde el primer momento"
    },
    {
      "type": "richtext",
      "id": "body_1",
      "label": "Paragraph 1",
      "default": "<p><strong>Fair Play For Men</strong> es un suplemento de fibra dietaria que ayuda a mantener un adecuado transito intestinal y contribuye con la higiene personal. En pocas palabras, es un aliado para experimentar encuentros mas limpios y placenteros.</p>"
    },
    {
      "type": "richtext",
      "id": "body_2",
      "label": "Paragraph 2",
      "default": "<p>Las fibras 100% naturales, debidamente hidratadas con agua, funcionan como un agente de limpieza a medida que pasan a traves del sistema digestivo, reduciendo significativamente el uso de enemas y el tiempo que dedicas para estar preparado.</p>"
    },
    {
      "type": "richtext",
      "id": "body_3",
      "label": "Paragraph 3",
      "default": "<p>Adicionalmente, nuestra formula exclusiva incluye <strong>Ganoderma Lucidum</strong> y <strong>Colageno Hidrolizado</strong>, ingredientes que fortalecen el sistema inmunologico y nutren el cabello, la piel, los huesos y las unas.</p>"
    },
    {
      "type": "range",
      "id": "text_width",
      "label": "Text container width",
      "min": 280,
      "max": 1280,
      "step": 20,
      "unit": "px",
      "default": 560
    },
    {
      "type": "range",
      "id": "section_width",
      "label": "Section content width",
      "min": 320,
      "max": 1280,
      "step": 20,
      "unit": "px",
      "default": 900
    },
    {
      "type": "header",
      "content": "Texto"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Alineación desktop",
      "options": [
        { "value": "left", "label": "Izquierda" },
        { "value": "center", "label": "Centro" },
        { "value": "right", "label": "Derecha" }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "text_alignment_mobile",
      "label": "Alineación mobile",
      "options": [
        { "value": "", "label": "— igual que desktop —" },
        { "value": "left", "label": "Izquierda" },
        { "value": "center", "label": "Centro" },
        { "value": "right", "label": "Derecha" }
      ],
      "default": ""
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Tamaño título desktop",
      "min": 20,
      "max": 72,
      "step": 2,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "title_size_mobile",
      "label": "Tamaño título mobile",
      "min": 14,
      "max": 52,
      "step": 2,
      "unit": "px",
      "default": 36
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_block_start",
      "label": "Top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 72
    },
    {
      "type": "range",
      "id": "padding_block_end",
      "label": "Bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 24
    }
  ],
  "presets": [
    {
      "name": "Fair Play Intro"
    }
  ]
}
{% endschema %}
