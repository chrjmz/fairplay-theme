{% liquid
  assign selected_product = section.settings.product
  if selected_product == blank and product != blank
    assign selected_product = product
  endif

  assign default_buy_link = routes.all_products_collection_url
  if selected_product != blank
    assign buy_link = selected_product.url
  elsif section.settings.buy_link != blank
    assign buy_link = section.settings.buy_link
  else
    assign buy_link = default_buy_link
  endif

  assign anchor_id = section.settings.anchor_id | strip

  if section.settings.product_image != blank
    assign product_image = section.settings.product_image | image_url: width: 900
  elsif selected_product != blank and selected_product.featured_image != blank
    assign product_image = selected_product.featured_image | image_url: width: 900
  else
    assign product_image = 'https://fairplay4men.com/wp-content/uploads/2023/08/tarro_fairplay-1.png'
  endif

  if section.settings.diagram_image != blank
    assign diagram_image = section.settings.diagram_image | image_url: width: 900
  else
    assign diagram_image = 'https://fairplay4men.com/wp-content/uploads/2021/04/Recurso-8egoshop-2.png'
  endif

  if section.settings.diagram_image_mobile != blank
    assign diagram_image_mobile = section.settings.diagram_image_mobile | image_url: width: 700
  else
    assign diagram_image_mobile = 'https://fairplay4men.com/wp-content/uploads/2021/04/fairPlay_landing_movilno-hacer-caso-a-fotos-04.png'
  endif

  if section.settings.product_title != blank
    assign product_title = section.settings.product_title
  elsif selected_product != blank
    assign product_title = selected_product.title
  else
    assign product_title = blank
  endif

  if section.settings.product_copy != blank
    assign product_copy = section.settings.product_copy
  elsif selected_product != blank and selected_product.description != blank
    assign product_copy = selected_product.description | strip_html | truncate: 150
  else
    assign product_copy = blank
  endif
%}

{{ 'fairplay-home.css' | asset_url | stylesheet_tag }}

<section
  {% if anchor_id != blank %}
    id="{{ anchor_id | escape }}"
  {% endif %}
  class="fairplay-home-section fairplay-home-recommendations section section--full-width color-scheme-1"
  style="--fairplay-padding-top: {{ section.settings.padding_block_start }}px; --fairplay-padding-bottom: {{ section.settings.padding_block_end }}px; --fairplay-recommendations-product-width: {{ section.settings.product_image_width | default: 168 }}px; --fairplay-recommendations-product-width-mobile: {{ section.settings.product_image_width_mobile | default: 148 }}px; --fairplay-recommendations-diagram-width: {{ section.settings.diagram_image_width | default: 120 }}px; --fairplay-recommendations-diagram-width-mobile: {{ section.settings.diagram_image_width_mobile | default: 108 }}px;"
>
  <div class="fairplay-home-section__wrap fairplay-home-recommendations__grid">
    <div class="fairplay-home-recommendations__copy">
      {% if section.settings.eyebrow != blank %}
        <p class="fairplay-home-eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}
      {% if section.settings.title != blank %}
        <h2 class="fairplay-home-title">{{ section.settings.title }}</h2>
      {% endif %}
      <div class="fairplay-home-body-copy">
        {{ section.settings.body_1 }}
        {{ section.settings.body_2 }}
        {{ section.settings.body_3 }}
      </div>
    </div>

    <div class="fairplay-home-recommendations__detail">
      <div class="fairplay-home-recommendations__panel">
        <a
          class="fairplay-home-recommendations__product-link"
          href="{{ buy_link }}"
          aria-label="Comprar {% if product_title != blank %}{{ product_title | escape }}{% else %}Fair Play For Men{% endif %}"
        >
          <img
            src="{{ product_image }}"
            alt="{% if product_title != blank %}{{ product_title | escape }}{% else %}Presentacion Fair Play For Men{% endif %}"
            loading="lazy"
          >
        </a>
        <div>
          {% if product_title != blank %}
            <h3>{{ product_title }}</h3>
          {% endif %}
          {% if product_copy != blank %}
            <p>{{ product_copy }}</p>
          {% endif %}
        </div>
      </div>

      <div class="fairplay-home-recommendations__panel">
        <picture>
          <source
            media="(max-width: 749px)"
            srcset="{{ diagram_image_mobile }}"
          >
          <img
            src="{{ diagram_image }}"
            alt="Modo de uso Fair Play For Men"
            loading="lazy"
          >
        </picture>
        <div>
          <h3>{{ section.settings.dose_title }}</h3>
          <p>{{ section.settings.dose_copy }}</p>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Fair Play Recommendations",
  "tag": "section",
  "class": "section-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "anchor_id",
      "label": "Anchor ID",
      "default": "recomendaciones"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Recomendaciones"
    },
    {
      "type": "textarea",
      "id": "title",
      "label": "Title",
      "default": "Juega a tu ritmo, juega limpio"
    },
    {
      "type": "richtext",
      "id": "body_1",
      "label": "Paragraph 1",
      "default": "<p><strong>Precauciones:</strong> No exceda la dosis diaria recomendada. Este producto debe ser consumido luego de ser diluido en agua; consumirlo en polvo podria causar asfixia. Si al consumir el producto surgen sintomas como dolor en el pecho, vomito, dificultad para respirar o tragar, o alguna otra reaccion alergica, busque inmediatamente atencion medica.</p>"
    },
    {
      "type": "richtext",
      "id": "body_2",
      "label": "Paragraph 2",
      "default": "<p>Evite su uso en mujeres en embarazo o en periodo de lactancia, asi como en personas con dolor abdominal o sintomas de diarrea. En caso de estar consumiendo algun medicamento o en medio de un tratamiento medico, consulte con su medico antes de hacer uso de este producto. <strong>Producto sugerido para personas mayores de 18 anos.</strong></p>"
    },
    {
      "type": "richtext",
      "id": "body_3",
      "label": "Paragraph 3",
      "default": "<p><strong>Conservacion:</strong> Conservese en su envase original, a temperatura ambiente y en un lugar fresco, ventilado y seco. Cerciorese de cerrarlo hermeticamente despues de cada uso para evitar su contaminacion y humedad.</p>"
    },
    {
      "type": "product",
      "id": "product",
      "label": "Linked product"
    },
    {
      "type": "image_picker",
      "id": "product_image",
      "label": "Custom product image"
    },
    {
      "type": "url",
      "id": "buy_link",
      "label": "Fallback buy link"
    },
    {
      "type": "range",
      "id": "product_image_width",
      "label": "Product desktop width",
      "min": 100,
      "max": 280,
      "step": 4,
      "unit": "px",
      "default": 168
    },
    {
      "type": "range",
      "id": "product_image_width_mobile",
      "label": "Product mobile width",
      "min": 80,
      "max": 220,
      "step": 4,
      "unit": "px",
      "default": 148
    },
    {
      "type": "text",
      "id": "product_title",
      "label": "Product title",
      "default": "Presentacion"
    },
    {
      "type": "textarea",
      "id": "product_copy",
      "label": "Product copy",
      "default": "Fair Play For Men viene en polvo porque al mezclarse con agua hidrata mejor la linaza, la chia y las cascaras de psyllium. De esa hidratacion depende la consistencia necesaria para arrastrar los residuos del tracto intestinal."
    },
    {
      "type": "image_picker",
      "id": "diagram_image",
      "label": "Diagram image"
    },
    {
      "type": "image_picker",
      "id": "diagram_image_mobile",
      "label": "Diagram mobile image"
    },
    {
      "type": "range",
      "id": "diagram_image_width",
      "label": "Diagram desktop width",
      "min": 80,
      "max": 220,
      "step": 4,
      "unit": "px",
      "default": 120
    },
    {
      "type": "range",
      "id": "diagram_image_width_mobile",
      "label": "Diagram mobile width",
      "min": 60,
      "max": 180,
      "step": 4,
      "unit": "px",
      "default": 108
    },
    {
      "type": "text",
      "id": "dose_title",
      "label": "Dose title",
      "default": "Dosis"
    },
    {
      "type": "textarea",
      "id": "dose_copy",
      "label": "Dose copy",
      "default": "Consumir 6 gramos, equivalentes a 2 porciones del dosificador incluido en el producto, maximo dos veces al dia, disueltas en 240 ml de agua."
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_block_start",
      "label": "Top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 72
    },
    {
      "type": "range",
      "id": "padding_block_end",
      "label": "Bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 24
    }
  ],
  "presets": [
    {
      "name": "Fair Play Recommendations"
    }
  ]
}
{% endschema %}
