{% liquid
  assign anchor_id = section.settings.anchor_id | strip

  if section.settings.lifestyle_image != blank
    assign lifestyle_image = section.settings.lifestyle_image | image_url: width: 900
  else
    assign lifestyle_image = 'https://fairplay4men.com/wp-content/uploads/2021/04/Recurso-7egoshop-2-1.png'
  endif

  if section.settings.diagram_image != blank
    assign diagram_image = section.settings.diagram_image | image_url: width: 900
  else
    assign diagram_image = 'https://fairplay4men.com/wp-content/uploads/2021/04/Recurso-8egoshop-2.png'
  endif

  if section.settings.diagram_image_mobile != blank
    assign diagram_image_mobile = section.settings.diagram_image_mobile | image_url: width: 700
  else
    assign diagram_image_mobile = 'https://fairplay4men.com/wp-content/uploads/2021/04/fairPlay_landing_movilno-hacer-caso-a-fotos-04.png'
  endif

  case section.settings.text_alignment
    when 'center'
      assign justify_items = 'center'
    when 'right'
      assign justify_items = 'end'
    else
      assign justify_items = 'start'
  endcase

  case section.settings.text_alignment_mobile
    when 'left'
      assign justify_items_mobile = 'start'
    when 'center'
      assign justify_items_mobile = 'center'
    when 'right'
      assign justify_items_mobile = 'end'
    else
      assign justify_items_mobile = justify_items
  endcase
%}

{{ 'fairplay-home.css' | asset_url | stylesheet_tag }}

<section
  {% if anchor_id != blank %}
    id="{{ anchor_id | escape }}"
  {% endif %}
  class="fairplay-home-section fairplay-home-recommendations section section--full-width color-scheme-1"
  style="--fairplay-padding-top: {{ section.settings.padding_block_start }}px; --fairplay-padding-bottom: {{ section.settings.padding_block_end }}px; --fairplay-section-width: {{ section.settings.section_width | default: 900 }}px; --fairplay-recommendations-copy-width: {{ section.settings.text_width | default: 330 }}px; --fairplay-recommendations-photo-width: {{ section.settings.lifestyle_image_width | default: 236 }}px; --fairplay-recommendations-photo-width-mobile: {{ section.settings.lifestyle_image_width_mobile | default: 260 }}px; --fairplay-recommendations-diagram-width: {{ section.settings.diagram_image_width | default: 120 }}px; --fairplay-recommendations-diagram-width-mobile: {{ section.settings.diagram_image_width_mobile | default: 108 }}px; --fairplay-text-align: {{ section.settings.text_alignment | default: 'left' }}; --fairplay-justify-items: {{ justify_items | default: 'start' }}; --fairplay-text-align-mobile: {{ section.settings.text_alignment_mobile | default: section.settings.text_alignment | default: 'left' }}; --fairplay-justify-items-mobile: {{ justify_items_mobile | default: justify_items | default: 'start' }}; --fairplay-title-size: {{ section.settings.title_size | default: 48 }}px; --fairplay-title-size-mobile: {{ section.settings.title_size_mobile | default: 36 }}px;"
>
  <div class="fairplay-home-section__wrap fairplay-home-recommendations__grid">
    <div class="fairplay-home-recommendations__copy">
      {% if section.settings.eyebrow != blank %}
        <p class="fairplay-home-eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}
      {% if section.settings.title != blank %}
        <h2 class="fairplay-home-title">{{ section.settings.title }}</h2>
      {% endif %}
      <div class="fairplay-home-body-copy">
        {{ section.settings.body_1 }}
        {{ section.settings.body_2 }}
        {{ section.settings.body_3 }}
      </div>
    </div>

    <div class="fairplay-home-recommendations__photo">
      <img
        src="{{ lifestyle_image }}"
        alt="{{ section.settings.lifestyle_image_alt | escape | default: 'Fair Play For Men' }}"
        width="{{ section.settings.lifestyle_image.width | default: 529 }}"
        height="{{ section.settings.lifestyle_image.height | default: 850 }}"
        loading="lazy"
      >
    </div>

    <div class="fairplay-home-recommendations__detail">
      <div class="fairplay-home-recommendations__panel">
        <picture>
          <source
            media="(max-width: 749px)"
            srcset="{{ diagram_image_mobile }}"
          >
          <img
            src="{{ diagram_image }}"
            alt="Modo de uso Fair Play For Men"
            width="{{ section.settings.diagram_image.width | default: 131 }}"
            height="{{ section.settings.diagram_image.height | default: 439 }}"
            loading="lazy"
          >
        </picture>
        <div>
          <h3>{{ section.settings.dose_title }}</h3>
          <p>{{ section.settings.dose_copy }}</p>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Fair Play Recommendations",
  "tag": "section",
  "class": "section-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "anchor_id",
      "label": "Anchor ID",
      "default": "recomendaciones"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Recomendaciones"
    },
    {
      "type": "textarea",
      "id": "title",
      "label": "Title",
      "default": "Juega a tu ritmo, juega limpio"
    },
    {
      "type": "header",
      "content": "Texto"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Alineacion desktop",
      "options": [
        { "value": "left", "label": "Izquierda" },
        { "value": "center", "label": "Centro" },
        { "value": "right", "label": "Derecha" }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "text_alignment_mobile",
      "label": "Alineacion mobile",
      "options": [
        { "value": "", "label": "Igual que desktop" },
        { "value": "left", "label": "Izquierda" },
        { "value": "center", "label": "Centro" },
        { "value": "right", "label": "Derecha" }
      ],
      "default": ""
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Tamano titulo desktop",
      "min": 20,
      "max": 72,
      "step": 2,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "title_size_mobile",
      "label": "Tamano titulo mobile",
      "min": 14,
      "max": 52,
      "step": 2,
      "unit": "px",
      "default": 36
    },
    {
      "type": "richtext",
      "id": "body_1",
      "label": "Paragraph 1",
      "default": "<p><strong>Precauciones:</strong> No exceda la dosis diaria recomendada. Este producto debe ser consumido luego de ser diluido en agua; consumirlo en polvo podria causar asfixia. Si al consumir el producto surgen sintomas como dolor en el pecho, vomito, dificultad para respirar o tragar, o alguna otra reaccion alergica, busque inmediatamente atencion medica.</p>"
    },
    {
      "type": "richtext",
      "id": "body_2",
      "label": "Paragraph 2",
      "default": "<p>Evite su uso en mujeres en embarazo o en periodo de lactancia, asi como en personas con dolor abdominal o sintomas de diarrea. En caso de estar consumiendo algun medicamento o en medio de un tratamiento medico, consulte con su medico antes de hacer uso de este producto. <strong>Producto sugerido para personas mayores de 18 anos.</strong></p>"
    },
    {
      "type": "richtext",
      "id": "body_3",
      "label": "Paragraph 3",
      "default": "<p><strong>Conservacion:</strong> Conservese en su envase original, a temperatura ambiente y en un lugar fresco, ventilado y seco. Cerciorese de cerrarlo hermeticamente despues de cada uso para evitar su contaminacion y humedad.</p>"
    },
    {
      "type": "range",
      "id": "text_width",
      "label": "Text container width",
      "min": 280,
      "max": 1280,
      "step": 20,
      "unit": "px",
      "default": 340
    },
    {
      "type": "range",
      "id": "section_width",
      "label": "Section content width",
      "min": 320,
      "max": 1280,
      "step": 20,
      "unit": "px",
      "default": 900
    },
    {
      "type": "header",
      "content": "Imagenes"
    },
    {
      "type": "range",
      "id": "lifestyle_image_width",
      "label": "Tamano foto desktop",
      "min": 160,
      "max": 1600,
      "step": 4,
      "unit": "px",
      "default": 236
    },
    {
      "type": "range",
      "id": "lifestyle_image_width_mobile",
      "label": "Tamano foto mobile",
      "min": 160,
      "max": 1600,
      "step": 4,
      "unit": "px",
      "default": 260
    },
    {
      "type": "image_picker",
      "id": "lifestyle_image",
      "label": "Lifestyle image"
    },
    {
      "type": "text",
      "id": "lifestyle_image_alt",
      "label": "Lifestyle image alt",
      "default": "Fair Play For Men"
    },
    {
      "type": "image_picker",
      "id": "diagram_image",
      "label": "Diagram image"
    },
    {
      "type": "image_picker",
      "id": "diagram_image_mobile",
      "label": "Diagram mobile image"
    },
    {
      "type": "range",
      "id": "diagram_image_width",
      "label": "Diagram desktop width",
      "min": 80,
      "max": 1600,
      "step": 4,
      "unit": "px",
      "default": 120
    },
    {
      "type": "range",
      "id": "diagram_image_width_mobile",
      "label": "Diagram mobile width",
      "min": 60,
      "max": 1600,
      "step": 4,
      "unit": "px",
      "default": 420
    },
    {
      "type": "text",
      "id": "dose_title",
      "label": "Dose title",
      "default": "Dosis"
    },
    {
      "type": "textarea",
      "id": "dose_copy",
      "label": "Dose copy",
      "default": "Consumir 6 gramos, equivalentes a 2 porciones del dosificador incluido en el producto, maximo dos veces al dia, disueltas en 240 ml de agua."
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_block_start",
      "label": "Top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 72
    },
    {
      "type": "range",
      "id": "padding_block_end",
      "label": "Bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 24
    }
  ],
  "presets": [
    {
      "name": "Fair Play Recommendations"
    }
  ]
}
{% endschema %}
