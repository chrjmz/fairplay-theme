{% liquid
  assign anchor_id = section.settings.anchor_id | strip

  if section.settings.warning_image != blank
    assign warning_image = section.settings.warning_image | image_url: width: 560
  endif
%}

{{ 'fairplay-home.css' | asset_url | stylesheet_tag }}

<section
  {% if anchor_id != blank %}
    id="{{ anchor_id | escape }}"
  {% endif %}
  class="fairplay-home-section fairplay-home-warning section section--full-width color-scheme-1"
  style="--fairplay-padding-top: {{ section.settings.padding_block_start }}px; --fairplay-padding-bottom: {{ section.settings.padding_block_end }}px;"
>
  <div class="fairplay-home-section__wrap fairplay-home-warning__wrap">
    {% if warning_image != blank %}
      <img
        class="fairplay-home-warning__image"
        src="{{ warning_image }}"
        alt="Advertencia Fair Play"
        width="{{ section.settings.warning_image.width | default: 560 }}"
        height="{{ section.settings.warning_image.height | default: 560 }}"
        loading="lazy"
      >
    {% endif %}
    <div class="fairplay-home-richtext fairplay-home-warning__copy">
      {{ section.settings.copy }}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Fair Play Warning",
  "tag": "section",
  "class": "section-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "anchor_id",
      "label": "Anchor ID",
      "default": "warning"
    },
    {
      "type": "image_picker",
      "id": "warning_image",
      "label": "Warning image"
    },
    {
      "type": "richtext",
      "id": "copy",
      "label": "Copy",
      "default": "<p>Manténgase fuera del alcance de los niños. Bajo condiciones de buen uso y almacenamiento, este producto tiene una vida útil de 24 meses. Evite consumir el producto si el sello de la tapa está roto o deteriorado. Verificar su fecha de vencimiento antes de consumir. <strong>ESTE PRODUCTO ES UN SUPLEMENTO DIETARIO. NO ES UN MEDICAMENTO Y NO SUPLE UNA ALIMENTACIÓN EQUILIBRADA</strong></p>"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_block_start",
      "label": "Top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 28
    },
    {
      "type": "range",
      "id": "padding_block_end",
      "label": "Bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 28
    }
  ],
  "presets": [
    {
      "name": "Fair Play Warning"
    }
  ]
}
{% endschema %}
